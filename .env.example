# ===== Gestor de Notas Privadas — Environment Variables =====

# Secret key for JWT token signing (CHANGE THIS in production!)
# Genera con: openssl rand -hex 64
JWT_SECRET=b6b06380628e8331da294cfdb6392beadcd9a43a051d95c25e4c02377fd4206c9a40536be070dd4d7f57cdcd4dbf2dfda93ec66e7b7e289c025d57b98d25ca66

# Token expiration in hours
JWT_EXPIRATION_HOURS=1

# Clave de cifrado de notas (CHANGE THIS in production!)
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_MASTER_KEY=457ac2823a073f1dcb8dc18eb78536761ed81e0daebe32eb245b0aee2c2e0b52

# Server port
PORT=5000

# SQLite database path (inside container: /app/data/notes.db)
DATABASE_URL=/app/data/notes.db

# Flask debug mode (0 = off, 1 = on) — NEVER set to 1 in production
FLASK_DEBUG=0

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5000
