# Security: exclude sensitive and unnecessary files from Docker image build context

# Environment files (NEVER include in image)
.env
.env.*

# Python cache
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.egg-info/

# Test files (not needed in production image)
tests/
.pytest_cache/
*.bak

# Local databases
*.db
data/

# Virtual environments
venv/
.venv/
ENV/

# Git
.git/
.gitignore

# Agents and docs
*.agent
*.md
