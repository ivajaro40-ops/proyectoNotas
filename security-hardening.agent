## MÓDULO 4 — DEFENSA ANTI-INYECCIÓN TOTAL

### 4.1 ORM Obligatorio — Cero SQL Manual

Migrar cualquier query SQL cruda a SQLAlchemy ORM:

```python
# ❌ NUNCA — Vulnerable a SQL Injection
query = f"SELECT * FROM notes WHERE title LIKE '%{search_term}%'"

# ✅ SIEMPRE — Parámetros escapados automáticamente por SQLAlchemy
notes = Note.query.filter(
    Note.user_id == g.user_id,
    Note.title.ilike(f"%{search_term}%")  # ilike ya escapa correctamente
).all()
```

### 4.2 Sanitización de Entradas con bleach

```python
# pip install bleach
import bleach

# Configuración estricta: solo texto plano, sin HTML
ALLOWED_TAGS = []          # Sin tags HTML en títulos
ALLOWED_ATTRS = {}

# Para contenido que permita formato básico (opcional):
ALLOWED_TAGS_CONTENT = ['b', 'i', 'u', 'em', 'strong', 'p', 'br', 'ul', 'ol', 'li']

def sanitize_text(value: str, allow_basic_html: bool = False) -> str:
    """Sanitiza texto eliminando HTML peligroso."""
    if not isinstance(value, str):
        raise ValueError("Se esperaba una cadena de texto.")
    tags = ALLOWED_TAGS_CONTENT if allow_basic_html else ALLOWED_TAGS
    return bleach.clean(value.strip(), tags=tags, attributes=ALLOWED_ATTRS)

def validate_and_sanitize_note(data: dict) -> tuple[dict, list[str]]:
    """Valida y sanitiza los datos de una nota. Devuelve (datos_limpios, errores)."""
    errors = []
    clean = {}

    title = data.get('title', '')
    content = data.get('content', '')

    if not title or len(title.strip()) == 0:
        errors.append("El título es obligatorio.")
    elif len(title) > 200:
        errors.append("El título no puede superar 200 caracteres.")
    else:
        clean['title'] = sanitize_text(title)

    if len(content) > 50_000:
        errors.append("El contenido no puede superar 50.000 caracteres.")
    else:
        clean['content'] = sanitize_text(content, allow_basic_html=False)

    return clean, errors
```

