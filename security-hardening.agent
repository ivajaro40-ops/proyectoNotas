## MÓDULO 1 — FORTALEZA DE AUTENTICACIÓN

### 1.1 Política de Contraseñas de Nivel Empresarial

Implementa en el endpoint `/register` una validación estricta:

```python
import re
from dataclasses import dataclass

@dataclass
class PasswordPolicy:
    min_length: int = 12
    require_uppercase: bool = True
    require_lowercase: bool = True
    require_digits: bool = True
    require_special: bool = True
    special_chars: str = "!@#$%^&*()_+-=[]{}|;:,.<>?"
    max_length: int = 128  # Previene DoS por bcrypt con contraseñas enormes

def validate_password(password: str) -> tuple[bool, list[str]]:
    """Valida la contraseña contra la política empresarial. Devuelve (válida, errores)."""
    policy = PasswordPolicy()
    errors = []

    if len(password) < policy.min_length:
        errors.append(f"Mínimo {policy.min_length} caracteres.")
    if len(password) > policy.max_length:
        errors.append(f"Máximo {policy.max_length} caracteres.")
    if policy.require_uppercase and not re.search(r'[A-Z]', password):
        errors.append("Debe contener al menos una mayúscula.")
    if policy.require_lowercase and not re.search(r'[a-z]', password):
        errors.append("Debe contener al menos una minúscula.")
    if policy.require_digits and not re.search(r'\d', password):
        errors.append("Debe contener al menos un número.")
    if policy.require_special and not any(c in policy.special_chars for c in password):
        errors.append("Debe contener al menos un carácter especial.")

    # Comprueba contraseñas comunes (lista mínima hardcodeada, ampliar con archivo)
    COMMON_PASSWORDS = {"password123", "admin1234", "qwerty123", "12345678901 2"}
    if password.lower() in COMMON_PASSWORDS:
        errors.append("Contraseña demasiado común. Elige una más única.")

    return len(errors) == 0, errors
```

### 1.2 bcrypt con Work Factor Adaptativo

```python
import bcrypt
import time

def get_optimal_bcrypt_rounds(target_ms: int = 250) -> int:
    """Calcula el número de rounds de bcrypt para que el hash tarde ~target_ms ms."""
    rounds = 10
    while rounds <= 15:
        start = time.time()
        bcrypt.hashpw(b"benchmark_password", bcrypt.gensalt(rounds=rounds))
        elapsed_ms = (time.time() - start) * 1000
        if elapsed_ms >= target_ms:
            return rounds
        rounds += 1
    return 12  # Fallback seguro

# En producción usa mínimo 12 rounds. Nunca menos.
BCRYPT_ROUNDS = int(os.environ.get('BCRYPT_ROUNDS', get_optimal_bcrypt_rounds()))
```

### 1.3 Protección Anti-Timing Attack en Login

```python
import hmac

def verify_password_safe(plain: str, hashed: bytes) -> bool:
    """
    Verificación de contraseña resistente a timing attacks.
    bcrypt.checkpw ya es resistente, pero añadimos una capa extra con hmac.compare_digest
    para la comparación del resultado booleano.
    """
    try:
        result = bcrypt.checkpw(plain.encode('utf-8'), hashed)
        # Comparación de tiempo constante del booleano
        return hmac.compare_digest(str(result).encode(), b'True')
    except Exception:
        return False
```

### 1.4 Implementar TOTP (2FA) Opcional

```python
# Instalar: pip install pyotp qrcode[pil]
import pyotp
import qrcode
import io, base64

def generate_totp_secret(user_id: int) -> str:
    """Genera un secreto TOTP único para el usuario."""
    return pyotp.random_base32()

def verify_totp(secret: str, token: str) -> bool:
    """Verifica un código TOTP con una ventana de tiempo de ±1 intervalo."""
    totp = pyotp.TOTP(secret)
    return totp.verify(token, valid_window=1)

def get_totp_qr_base64(secret: str, user_email: str, app_name: str = "NotasPrivadas") -> str:
    """Genera un QR code en base64 para configurar apps autenticadoras."""
    uri = pyotp.totp.TOTP(secret).provisioning_uri(name=user_email, issuer_name=app_name)
    qr = qrcode.make(uri)
    buffer = io.BytesIO()
    qr.save(buffer, format="PNG")
    return base64.b64encode(buffer.getvalue()).decode()
```

