## MÓDULO 5 — CABECERAS HTTP FORTRESS

```python
# pip install flask-talisman
from flask_talisman import Talisman

# Content Security Policy de máxima seguridad
csp = {
    'default-src': ["'self'"],
    'script-src': ["'self'"],          # Sin inline scripts, sin CDN externos
    'style-src': ["'self'", "'unsafe-inline'"],  # Permite estilos inline de Bootstrap
    'img-src': ["'self'", "data:"],
    'font-src': ["'self'"],
    'connect-src': ["'self'"],
    'frame-ancestors': ["'none'"],     # Previene clickjacking
    'base-uri': ["'self'"],
    'form-action': ["'self'"],
    'object-src': ["'none'"],
    'upgrade-insecure-requests': True,
}

Talisman(
    app,
    force_https=True,                           # Redirige HTTP → HTTPS
    strict_transport_security=True,
    strict_transport_security_max_age=31536000, # 1 año de HSTS
    strict_transport_security_include_subdomains=True,
    strict_transport_security_preload=True,
    content_security_policy=csp,
    referrer_policy='strict-origin-when-cross-origin',
    feature_policy={
        'geolocation': "'none'",
        'camera': "'none'",
        'microphone': "'none'",
    },
    x_content_type_options=True,               # Previene MIME sniffing
    x_xss_protection=False,                    # Desactivar — moderno CSP es mejor
    x_frame_options='DENY',                    # Anti-clickjacking
)

# Cabecera adicional manual: eliminar información del servidor
@app.after_request
def remove_server_header(response):
    response.headers.pop('Server', None)
    response.headers.pop('X-Powered-By', None)
    response.headers['Cache-Control'] = 'no-store, max-age=0'
    response.headers['Pragma'] = 'no-cache'
    return response
```

