## MÓDULO 9 — WAF LIGERO (WEB APPLICATION FIREWALL)

```python
import re
from flask import request, abort

# Patrones de ataque conocidos
ATTACK_PATTERNS = [
    # SQL Injection
    re.compile(r"(\bUNION\b|\bSELECT\b|\bDROP\b|\bINSERT\b|\bDELETE\b|\bUPDATE\b)", re.IGNORECASE),
    # XSS básico
    re.compile(r"<script[\s\S]*?>|javascript\s*:|on\w+\s*=", re.IGNORECASE),
    # Path Traversal
    re.compile(r"\.\./|\.\.\\|%2e%2e%2f|%2e%2e/", re.IGNORECASE),
    # Command Injection
    re.compile(r"[;&|`$]|\$\(|`.*`"),
    # LDAP Injection
    re.compile(r"[)(|&*!\\]"),
]

MAX_REQUEST_SIZE = 1 * 1024 * 1024  # 1 MB

@app.before_request
def waf_middleware():
    """WAF ligero que inspecciona todas las peticiones entrantes."""

    # 1. Limite de tamaño de petición
    content_length = request.content_length
    if content_length and content_length > MAX_REQUEST_SIZE:
        security_logger.warning("WAF_SIZE | IP=%s | size=%s", get_client_ip(), content_length)
        abort(413, description="Petición demasiado grande.")

    # 2. Validar Content-Type para peticiones con body
    if request.method in ['POST', 'PUT', 'PATCH']:
        ct = request.content_type or ''
        if not ct.startswith('application/json'):
            abort(415, description="Content-Type debe ser application/json.")

    # 3. Inspección de parámetros y body contra patrones de ataque
    # (Solo como capa adicional — el ORM y bleach son la defensa principal)
    inputs_to_check = []
    inputs_to_check.extend(request.args.values())
    inputs_to_check.extend(request.form.values())
    if request.is_json:
        inputs_to_check.extend(str(v) for v in (request.json or {}).values())

    for value in inputs_to_check:
        for pattern in ATTACK_PATTERNS:
            if pattern.search(str(value)):
                security_logger.critical(
                    "WAF_BLOCK | IP=%s | Pattern=%s | Path=%s",
                    get_client_ip(), pattern.pattern[:50], request.path
                )
                abort(400, description="Petición bloqueada.")
```

