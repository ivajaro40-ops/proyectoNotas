## MÓDULO 10 — LOGGING DE SEGURIDAD Y DETECCIÓN DE INTRUSIONES

```python
import logging
import logging.handlers
import json
from datetime import datetime, timezone

class SecurityJSONFormatter(logging.Formatter):
    """Formateador de logs en JSON estructurado para SIEM."""
    def format(self, record):
        log_entry = {
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "level": record.levelname,
            "event": record.getMessage(),
            "logger": record.name,
            "module": record.module,
            "line": record.lineno,
        }
        return json.dumps(log_entry, ensure_ascii=False)

def setup_security_logging(app):
    """Configura logging de seguridad estructurado con rotación de archivos."""

    # Logger de seguridad dedicado (separado del logger de aplicación)
    security_handler = logging.handlers.RotatingFileHandler(
        'logs/security.log',
        maxBytes=10 * 1024 * 1024,  # 10MB por archivo
        backupCount=30,              # Mantener 30 días de logs
        encoding='utf-8'
    )
    security_handler.setFormatter(SecurityJSONFormatter())
    security_handler.setLevel(logging.INFO)

    security_logger = logging.getLogger('security')
    security_logger.setLevel(logging.INFO)
    security_logger.addHandler(security_handler)
    security_logger.propagate = False  # No propagar al logger raíz

    # Eventos de seguridad a registrar (ejemplos de uso):
    # security_logger.info("AUTH_SUCCESS | user_id=%s | IP=%s", user_id, ip)
    # security_logger.warning("AUTH_FAIL | email=%s | IP=%s", email, ip)  ← SIN contraseña
    # security_logger.critical("IDOR_ATTEMPT | ...")

# Detección de anomalías básica
def detect_anomaly(event_type: str, ip: str):
    """Detecta patrones sospechosos y activa alertas."""
    THRESHOLDS = {
        "AUTH_FAIL": (10, 300),       # 10 fallos en 5 minutos → alerta
        "IDOR_ATTEMPT": (1, 60),      # Cualquier IDOR → alerta inmediata
        "WAF_BLOCK": (5, 60),         # 5 bloqueos WAF en 1 minuto → alerta
    }
    # Implementar con Redis para conteo en tiempo real
    # Enviar alerta por email/webhook si se supera el umbral
    pass
```

