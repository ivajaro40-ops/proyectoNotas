## MÓDULO 13 — TESTS DE PENETRACIÓN AUTOMATIZADOS

Crear el archivo `tests/test_security.py`:

```python
import pytest
import jwt
import json

class TestAuthSecurity:
    def test_login_returns_generic_error_for_invalid_credentials(self, client):
        """No debe revelar si el email existe o si la contraseña es incorrecta."""
        r1 = client.post('/api/auth/login', json={"email": "noexiste@test.com", "password": "mal"})
        r2 = client.post('/api/auth/login', json={"email": "existe@test.com", "password": "mal"})
        # Ambas respuestas deben ser idénticas (timing también, idealmente)
        assert r1.status_code == r2.status_code == 401
        assert r1.json == r2.json

    def test_jwt_algorithm_none_attack(self, client, valid_user):
        """El servidor debe rechazar tokens con alg: none."""
        # Crear token con alg: none manualmente
        header = {"alg": "none", "typ": "JWT"}
        payload = {"sub": str(valid_user.id), "type": "access", "exp": 9999999999}
        import base64
        none_token = (
            base64.urlsafe_b64encode(json.dumps(header).encode()).rstrip(b'=') + b'.' +
            base64.urlsafe_b64encode(json.dumps(payload).encode()).rstrip(b'=') + b'.'
        ).decode()
        r = client.get('/api/notes', headers={"Authorization": f"Bearer {none_token}"})
        assert r.status_code == 401

    def test_idor_protection(self, client, user_a_token, user_b_note):
        """El usuario A no debe poder acceder a las notas del usuario B."""
        r = client.get(
            f'/api/notes/{user_b_note.id}',
            headers={"Authorization": f"Bearer {user_a_token}"}
        )
        assert r.status_code in [403, 404]  # Nunca 200

    def test_sql_injection_in_search(self, client, auth_token):
        """La búsqueda debe ser inmune a SQL injection."""
        payloads = ["' OR '1'='1", "1; DROP TABLE notes--", "' UNION SELECT * FROM users--"]
        for payload in payloads:
            r = client.get(
                f'/api/notes?search={payload}',
                headers={"Authorization": f"Bearer {auth_token}"}
            )
            assert r.status_code in [200, 400], f"Payload peligroso no manejado: {payload}"

    def test_xss_sanitization_in_notes(self, client, auth_token):
        """El contenido XSS debe ser sanitizado al guardar."""
        xss_payloads = [
            "<script>alert('xss')</script>",
            "<img src=x onerror=alert(1)>",
            "javascript:alert(1)",
        ]
        for payload in xss_payloads:
            r = client.post(
                '/api/notes',
                json={"title": payload, "content": "test"},
                headers={"Authorization": f"Bearer {auth_token}"}
            )
            if r.status_code == 201:
                note_id = r.json['id']
                note = client.get(f'/api/notes/{note_id}', headers={"Authorization": f"Bearer {auth_token}"})
                assert '<script>' not in note.json.get('title', '')

    def test_rate_limiting_on_login(self, client):
        """El endpoint de login debe aplicar rate limiting."""
        for i in range(10):
            r = client.post('/api/auth/login', json={"email": "test@test.com", "password": "wrong"})
        assert r.status_code == 429

    def test_security_headers_present(self, client):
        """Todas las cabeceras de seguridad requeridas deben estar presentes."""
        r = client.get('/health')
        headers = r.headers
        assert 'X-Content-Type-Options' in headers
        assert 'X-Frame-Options' in headers
        assert 'Content-Security-Policy' in headers
        assert 'Strict-Transport-Security' in headers
        assert 'Server' not in headers  # No revelar versión del servidor

    def test_expired_token_rejected(self, client, valid_user):
        """Los tokens expirados deben ser rechazados."""
        expired_token = jwt.encode(
            {"sub": str(valid_user.id), "exp": 1, "iat": 1, "type": "access", "jti": "test"},
            os.environ['JWT_SECRET'], algorithm="HS256"
        )
        r = client.get('/api/notes', headers={"Authorization": f"Bearer {expired_token}"})
        assert r.status_code == 401

    def test_password_policy_enforcement(self, client):
        """El registro debe rechazar contraseñas débiles."""
        weak_passwords = ["123456", "password", "abc", "12345678"]
        for pwd in weak_passwords:
            r = client.post('/api/auth/register', json={"email": "new@test.com", "password": pwd})
            assert r.status_code == 400, f"Contraseña débil aceptada: {pwd}"
```

