## MÓDULO 8 — ENDURECIMIENTO DE CONTENEDORES DOCKER

### 8.1 Dockerfile Hardened

```dockerfile
# ---- Stage 1: Builder ----
FROM python:3.11-slim AS builder

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# ---- Stage 2: Runtime (superficie mínima) ----
FROM python:3.11-slim AS runtime

# Metadatos de seguridad
LABEL maintainer="tu@email.com"
LABEL org.opencontainers.image.description="Gestor de Notas Privadas - Hardened"

# Crear usuario no-root con UID/GID fijo (no usar UID < 1000)
RUN groupadd --gid 1001 appgroup && \
    useradd --uid 1001 --gid 1001 --no-create-home --shell /bin/false appuser

WORKDIR /app

# Copiar solo dependencias instaladas del builder
COPY --from=builder /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin
COPY --chown=appuser:appgroup . .

# Permisos restrictivos
RUN chmod -R 550 /app && \
    chmod -R 770 /app/instance  # Solo el directorio de BD necesita escritura

# Variables de seguridad del runtime de Python
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONFAULTHANDLER=0 \
    PYTHONHASHSEED=random

# Eliminar herramientas innecesarias
RUN apt-get purge -y --auto-remove curl wget && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

USER appuser

EXPOSE 5000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:5000/health')" || exit 1

CMD ["gunicorn", "--bind", "0.0.0.0:5000", "--workers", "2", "--threads", "2", \
     "--timeout", "30", "--max-requests", "1000", "--max-requests-jitter", "50", \
     "--access-logfile", "-", "--error-logfile", "-", \
     "app:app"]
```

### 8.2 docker-compose.yml Hardened

```yaml
version: '3.8'

services:
  app:
    build:
      context: ./backend
      dockerfile: Dockerfile
    restart: unless-stopped
    env_file: .env
    ports:
      - "127.0.0.1:5000:5000"    # Solo escuchar en localhost — Nginx hace el proxy
    volumes:
      - app_data:/app/instance    # Volumen nombrado, no bind mount
    networks:
      - internal
    security_opt:
      - no-new-privileges:true    # Previene escalada de privilegios
    read_only: true               # Filesystem de solo lectura
    tmpfs:
      - /tmp:size=50m,mode=1777   # /tmp en memoria, tamaño limitado
    cap_drop:
      - ALL                       # Eliminar todas las capabilities Linux
    cap_add:
      - NET_BIND_SERVICE          # Solo la necesaria para binding de puertos
    mem_limit: 256m
    memswap_limit: 256m
    pids_limit: 50
    ulimits:
      nofile:
        soft: 1024
        hard: 2048

  nginx:
    image: nginx:1.25-alpine
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/ssl:/etc/nginx/ssl:ro
      - nginx_logs:/var/log/nginx
    networks:
      - internal
      - external
    depends_on:
      - app
    security_opt:
      - no-new-privileges:true

volumes:
  app_data:
    driver: local
  nginx_logs:
    driver: local

networks:
  internal:
    driver: bridge
    internal: true       # Sin acceso a internet directo desde el contenedor de app
  external:
    driver: bridge
```

