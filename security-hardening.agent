## MÓDULO 6 — RATE LIMITING Y ANTI-FUERZA BRUTA

```python
# pip install flask-limiter
from flask_limiter import Limiter
from flask_limiter.util import get_remote_address
import time
from collections import defaultdict
import threading

limiter = Limiter(
    app=app,
    key_func=get_client_ip,               # Usa la IP real (respeta X-Forwarded-For)
    default_limits=["200 per day", "50 per hour"],
    storage_uri=os.environ.get('REDIS_URL', 'memory://'),  # Redis en producción
    headers_enabled=True,                  # Expone RateLimit-* headers
)

# Rutas con límites específicos
@app.route('/api/auth/login', methods=['POST'])
@limiter.limit("5 per minute; 20 per hour")
def login():
    pass

@app.route('/api/auth/register', methods=['POST'])
@limiter.limit("3 per hour")
def register():
    pass

# Bloqueo progresivo por IP con backoff exponencial
_login_attempts = defaultdict(list)
_lock = threading.Lock()

def check_progressive_lockout(ip: str) -> tuple[bool, int]:
    """
    Implementa bloqueo progresivo: 5 intentos → 30s, 10 → 5min, 20 → 1h.
    Devuelve (bloqueado, segundos_restantes).
    """
    now = time.time()
    with _lock:
        # Limpiar intentos antiguos (ventana de 1 hora)
        _login_attempts[ip] = [t for t in _login_attempts[ip] if now - t < 3600]
        attempts = len(_login_attempts[ip])

    if attempts >= 20:
        wait = 3600
    elif attempts >= 10:
        wait = 300
    elif attempts >= 5:
        wait = 30
    else:
        return False, 0

    last_attempt = _login_attempts[ip][-1] if _login_attempts[ip] else 0
    remaining = int(wait - (now - last_attempt))
    if remaining > 0:
        return True, remaining
    return False, 0

# Manejador de error 429
@app.errorhandler(429)
def rate_limit_exceeded(e):
    security_logger.warning("RATE_LIMIT | IP=%s | Path=%s", get_client_ip(), request.path)
    return {"error": "Demasiadas peticiones. Inténtalo más tarde."}, 429
```

