## MÓDULO 12 — SUPERFICIE DE ATAQUE MÍNIMA

```python
# 1. Eliminar rutas de debug/desarrollo
# Buscar y eliminar cualquier:
# @app.route('/debug'), @app.route('/test'), @app.route('/admin') sin protección

# 2. Health check seguro (sin información sensible)
@app.route('/health', methods=['GET'])
def health_check():
    """Health check mínimo que no expone información del sistema."""
    return {"status": "ok"}, 200
    # NUNCA: {"status": "ok", "version": "1.0", "db": "connected", "uptime": ...}

# 3. Manejadores de error genéricos (sin stack traces)
@app.errorhandler(400)
@app.errorhandler(401)
@app.errorhandler(403)
@app.errorhandler(404)
@app.errorhandler(405)
@app.errorhandler(413)
@app.errorhandler(429)
@app.errorhandler(500)
def generic_error_handler(e):
    """Manejador genérico que nunca expone información interna."""
    code = getattr(e, 'code', 500)
    # Loguear el error completo internamente
    if code == 500:
        app.logger.error("INTERNAL_ERROR | %s | IP=%s", str(e), get_client_ip())
    return {"error": getattr(e, 'description', 'Error en el servidor.')}, code

# 4. Configuración de Flask para producción
app.config.update(
    DEBUG=False,                            # NUNCA True en producción
    TESTING=False,
    PROPAGATE_EXCEPTIONS=False,
    TRAP_HTTP_EXCEPTIONS=False,
    MAX_CONTENT_LENGTH=1 * 1024 * 1024,    # 1MB máximo
    JSON_SORT_KEYS=False,
    SESSION_COOKIE_HTTPONLY=True,
    SESSION_COOKIE_SECURE=True,
    SESSION_COOKIE_SAMESITE='Strict',
    PERMANENT_SESSION_LIFETIME=timedelta(minutes=15),
    WTF_CSRF_ENABLED=True,                 # Si usas Flask-WTF
)
```

