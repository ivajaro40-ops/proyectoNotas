## MÓDULO 3 — AUTORIZACIÓN ZERO TRUST

### 3.1 Decorador de Seguridad Multicapa

```python
from functools import wraps
from flask import request, g, abort
import logging

security_logger = logging.getLogger('security')

def require_auth(f):
    """
    Decorador de autenticación que:
    1. Extrae y valida el JWT del header Authorization.
    2. Verifica que el token no está en la blacklist.
    3. Carga el usuario en el contexto global `g`.
    4. Registra el acceso en el log de seguridad.
    """
    @wraps(f)
    def decorated(*args, **kwargs):
        auth_header = request.headers.get('Authorization', '')
        if not auth_header.startswith('Bearer '):
            security_logger.warning(
                "AUTH_MISSING | IP=%s | Path=%s", get_client_ip(), request.path
            )
            abort(401, description="Token de autenticación requerido.")

        token = auth_header[7:]  # Elimina "Bearer "
        payload = decode_token_secure(token, expected_type="access")

        if not payload:
            security_logger.warning(
                "AUTH_INVALID | IP=%s | Path=%s", get_client_ip(), request.path
            )
            abort(401, description="Token inválido o expirado.")

        g.user_id = int(payload["sub"])
        g.jti = payload["jti"]
        return f(*args, **kwargs)
    return decorated

def require_note_ownership(f):
    """
    Decorador anti-IDOR: verifica que la nota pertenece al usuario autenticado.
    Úsalo siempre junto a @require_auth en rutas con <note_id>.
    """
    @wraps(f)
    def decorated(*args, note_id: int, **kwargs):
        note = db.execute(
            "SELECT user_id FROM notes WHERE id = ?", (note_id,)
        ).fetchone()

        if not note:
            abort(404)  # Existencia de la nota es información — no revelar si es 401 o 404

        if note['user_id'] != g.user_id:
            security_logger.critical(
                "IDOR_ATTEMPT | user_id=%s | note_id=%s | IP=%s",
                g.user_id, note_id, get_client_ip()
            )
            abort(404)  # Devuelve 404, no 403 — no confirma existencia del recurso

        return f(*args, note_id=note_id, **kwargs)
    return decorated

def get_client_ip() -> str:
    """Obtiene la IP real del cliente respetando proxies de confianza."""
    if request.headers.get('X-Forwarded-For'):
        # Solo confiar en la primera IP (cliente original)
        return request.headers.get('X-Forwarded-For').split(',')[0].strip()
    return request.remote_addr or 'unknown'
```

### 3.2 Uso en Rutas

```python
@app.route('/api/notes/<int:note_id>', methods=['GET', 'PUT', 'DELETE'])
@require_auth
@require_note_ownership
def note_detail(note_id: int):
    # En este punto GARANTIZAMOS que:
    # ✅ El usuario está autenticado (JWT válido y no revocado)
    # ✅ La nota existe y le pertenece al usuario autenticado
    pass
```

